{
  "expo": {
    "name": "msa",
    "slug": "msa",
    "version": "1.0.0",
    "scheme": "msa",
    "platforms": ["ios", "android"],
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./src/shared/assets/favicon.png"
    },
    "plugins": ["expo-router", "expo-notifications"],
    "experiments": {
      "typedRoutes": true,
      "tsconfigPaths": true
    },
    "orientation": "portrait",
    "icon": "./src/shared/assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./src/shared/assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "googleServicesFile": "process.env.EXPO_PUBLIC_GOOGLE_SERVICE",
      "adaptiveIcon": {
        "foregroundImage": "./src/shared/assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.pixelthread.msa"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "76bf6558-f870-4eb0-b4a2-698184fefb41"
      }
    },
    "owner": "pixel-thread"
  }
}
